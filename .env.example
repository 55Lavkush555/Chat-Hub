# MongoDB connection string (from MongoDB Atlas or local instance)
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/relay?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/relay?retryWrites=true&w=majority

# JWT secret used to sign and verify auth tokens
# Use a long, random string in production
JWT_SECRET=chat-app-secret-dev-key
